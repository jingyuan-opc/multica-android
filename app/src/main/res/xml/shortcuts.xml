            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.multica.android"
            android:targetClass="ai.multica.android.MainActivity"
            android:data="multica://issues" />
    </shortcut>

    <shortcut
        android:shortcutId="projects"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_projects"
        android:shortcutShortLabel="@string/shortcut_projects_short"
        android:shortcutLongLabel="@string/shortcut_projects_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="ai.multica.android"
            android:targetClass="ai.multica.android.MainActivity"
            android:data="multica://projects" />
